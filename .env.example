# Copy to .env and fill in values. Never commit .env.

# ── Feature Flags ─────────────────────────────────────────────────────────────
# Comma-separated list of enabled flags. All features default off.
# Available flags:
#   feature.temperature.thermal-profile
#   feature.flood.risk-analysis
#   feature.sunpath.diagram
#   feature.wind.climatology
FLAGS=

# ── Google Earth Engine ───────────────────────────────────────────────────────
GEE_PROJECT_ID=
GEE_SERVICE_ACCOUNT_EMAIL=
GEE_SERVICE_ACCOUNT_KEY_PATH=secrets/service-account.json

# ── Supabase (frontend auth + project persistence) ────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=

# ── Service URLs (used by frontend) ──────────────────────────────────────────
NEXT_PUBLIC_TEMPERATURE_API_URL=http://localhost:8000
NEXT_PUBLIC_SUNPATH_API_URL=http://localhost:8001
NEXT_PUBLIC_FLOOD_API_URL=http://localhost:8002
NEXT_PUBLIC_WIND_API_URL=http://localhost:8003

# ── Open-Meteo (no key required — public API) ─────────────────────────────────
# OPEN_METEO_BASE_URL defaults to https://archive-api.open-meteo.com/v1/archive

# ── IMD data (Temperature service) ───────────────────────────────────────────
IMD_DATA_DIR=./data

# ── Firebase (SiteAnalysisV2 frontend only) ───────────────────────────────────
# Only needed if running the SiteAnalysisV2 frontend
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
